# ─── Database ───
DATABASE_URL="postgresql://user:password@localhost:5432/ecommerce"

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── SMTP / Email ───
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
SMTP_FROM=noreply@yourdomain.com

# ─── App ───
APP_URL=http://localhost:3000
COOKIE_DOMAIN=.yourdomain.com
COOKIE_SAMESITE=lax
COOKIE_SECURE=
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
NODE_ENV=development

# ─── API Ports ───
STOREFRONT_API_PORT=4000
ADMIN_API_PORT=4002
SELLER_API_PORT=4003

# ─── Auth / JWT ───
JWT_ACCESS_SECRET=your-access-secret-change-me
JWT_REFRESH_SECRET=your-refresh-secret-change-me

# ─── Throttling (optional — defaults shown) ───
# THROTTLE_TTL_MS=60000
# THROTTLE_LIMIT=10
# THROTTLE_LIMIT_ADMIN=30

# ─── Next.js Public Variables ───
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:4002
NEXT_PUBLIC_SELLER_API_URL=http://localhost:4003
NEXT_PUBLIC_STOREFRONT_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
