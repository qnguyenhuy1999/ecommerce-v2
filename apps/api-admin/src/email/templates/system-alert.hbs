<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>System Alert</title>
</head>
<body style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
  <h1 style="color: #d32f2f;">System Alert: {{severity}}</h1>
  <p><strong>Service:</strong> {{service}}</p>
  <p><strong>Timestamp:</strong> {{timestamp}}</p>
  <p><strong>Message:</strong></p>
  <pre style="background: #f5f5f5; padding: 15px; border-radius: 4px; overflow-x: auto;">{{message}}</pre>
  {{#if actionRequired}}
  <p style="color: #d32f2f;"><strong>Action Required:</strong> {{actionRequired}}</p>
  {{/if}}
  <hr style="border: none; border-top: 1px solid #eee; margin: 30px 0;">
  <p style="color: #999; font-size: 12px;">This is an automated system alert. Do not reply to this email.</p>
</body>
</html>
