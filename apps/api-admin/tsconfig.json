{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Bundler",
    "ignoreDeprecations": "6.0",
    "outDir": "./dist",
    "rootDir": "../../",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@ecom/auth": ["../../packages/auth/src"],
      "@ecom/auth/*": ["../../packages/auth/src/*"],
      "@ecom/config": ["../../packages/config/src"],
      "@ecom/config/*": ["../../packages/config/src/*"],
      "@ecom/contracts": ["../../packages/contracts/src"],
      "@ecom/contracts/*": ["../../packages/contracts/src/*"],
      "@ecom/database": ["../../packages/database/src"],
      "@ecom/database/*": ["../../packages/database/src/*"],
      "@ecom/email": ["../../packages/email/src"],
      "@ecom/email/*": ["../../packages/email/src/*"],
      "@ecom/redis": ["../../packages/redis/src"],
      "@ecom/redis/*": ["../../packages/redis/src/*"],
      "@ecom/nestjs-core": ["../../packages/nestjs-core/src"],
      "@ecom/nestjs-core/*": ["../../packages/nestjs-core/src/*"],
      "@ecom/shared": ["../../packages/shared/src"],
      "@ecom/shared/constants": ["../../packages/shared/src/constants"],
      "@ecom/shared/pagination/core": ["../../packages/shared/src/pagination/core"],
      "@ecom/shared/pagination/nestjs": ["../../packages/shared/src/pagination/nestjs"],
      "@ecom/shared/pagination/prisma": ["../../packages/shared/src/pagination/prisma"],
      "@ecom/shared/utils": ["../../packages/shared/src/utils"],
      "@ecom/shared/errors": ["../../packages/shared/src/errors"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test"]
}
