{
  "name": "@ecom/api-storefront",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node --env-file=../../.env dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "pnpm exec eslint --no-error-on-unmatched-pattern src/",
    "type-check": "tsc --noEmit",
    "swagger:gen": "node --import @swc-node/register/esm-register --env-file-if-exists=../../.env src/generate-openapi.ts"
  },
  "dependencies": {
    "@ecom/auth": "workspace:*",
    "@ecom/config": "workspace:*",
    "@ecom/contracts": "workspace:*",
    "@ecom/database": "workspace:*",
    "@ecom/email": "workspace:*",
    "@ecom/nestjs-core": "workspace:*",
    "@ecom/redis": "workspace:*",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/throttler": "^6.5.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "ioredis": "^5.6.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@ecom/eslint-config": "workspace:*",
    "@nestjs/cli": "^11.0.21",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/node": "^25.7.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}