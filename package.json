{
  "name": "ecommerce",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint && pnpm -w run lint:comments",
    "lint:comments": "echo 'comment linting not yet configured'",
    "format": "pnpm -w exec prettier --write \"**/*.{ts,tsx,md,stories.tsx}\" --ignore-path .prettierignore \"!apps/api-admin/**\" \"!apps/api-seller/**\" \"!apps/api-storefront/**\" \"!apps/worker/**\" \"!packages/database/**\"",
    "format:check": "pnpm -w exec prettier --check \"**/*.{ts,tsx,md,stories.tsx}\" --ignore-path .prettierignore \"!apps/api-admin/**\" \"!apps/api-seller/**\" \"!apps/api-storefront/**\" \"!apps/worker/**\" \"!packages/database/**\"",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "db:generate": "cd packages/database && npx prisma generate",
    "db:migrate": "cd packages/database && npx prisma migrate dev",
    "db:seed": "cd packages/database && npx prisma db seed"
  },
  "devDependencies": {
    "@ecom/eslint-config": "workspace:*",
    "@eslint/js": "^9.26.0",
    "@storybook/react-vite": "^10.3.6",
    "dependency-cruiser": "^16.10.0",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.5",
    "madge": "^8.0.0",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0"
  },
  "prettier": "./.prettierrc.mjs",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.0.4"
}
