{
  "name": "@ecom/auth",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./password.utils": {
      "types": "./src/password.utils.ts",
      "import": "./dist/password.utils.js",
      "require": "./dist/password.utils.cjs"
    },
    "./client": {
      "import": "./src/next/client.tsx",
      "types": "./src/next/client.tsx"
    },
    "./protected-route": {
      "import": "./src/next/protected-route.ts",
      "types": "./src/next/protected-route.ts"
    },
    "./middleware": {
      "import": "./src/next/middleware.ts",
      "types": "./src/next/middleware.ts"
    }
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "pnpm exec eslint --no-error-on-unmatched-pattern src/",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ecom/database": "workspace:*",
    "bcryptjs": "^3.0.3",
    "ioredis": "^5.6.0"
  },
  "peerDependencies": {
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ecom/email": "workspace:*",
    "@ecom/eslint-config": "workspace:*",
    "@ecom/redis": "workspace:*",
    "@prisma/client": "^7.8.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.7.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3"
  }
}
