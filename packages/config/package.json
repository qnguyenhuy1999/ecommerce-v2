{
  "name": "@ecom/config",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./env": {
      "types": "./src/env/index.ts",
      "import": "./dist/env/index.js",
      "require": "./dist/env/index.cjs"
    },
    "./api-client": {
      "types": "./src/api-client.ts",
      "import": "./dist/api-client.js",
      "require": "./dist/api-client.cjs"
    }
  },
  "scripts": {
    "dev": "",
    "build": "tsup",
    "lint": "pnpm exec eslint --no-error-on-unmatched-pattern src/",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@ecom/eslint-config": "workspace:*",
    "@types/node": "^25.7.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3"
  }
}
