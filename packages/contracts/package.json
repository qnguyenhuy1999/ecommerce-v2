{
  "name": "@ecom/contracts",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "sideEffects": false,
  "files": [
    "src",
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./src/index.ts"
    },
    "./enums": {
      "import": "./dist/enums/index.js",
      "require": "./dist/enums/index.cjs",
      "types": "./src/enums/index.ts"
    },
    "./http": {
      "import": "./dist/http/index.js",
      "require": "./dist/http/index.cjs",
      "types": "./src/http/index.ts"
    },
    "./product": {
      "import": "./dist/product/index.js",
      "require": "./dist/product/index.cjs",
      "types": "./src/product/index.ts"
    },
    "./order": {
      "import": "./dist/order/index.js",
      "require": "./dist/order/index.cjs",
      "types": "./src/order/index.ts"
    },
    "./auth": {
      "import": "./dist/auth/index.js",
      "require": "./dist/auth/index.cjs",
      "types": "./src/auth/index.ts"
    },
    "./common": {
      "import": "./dist/common/index.js",
      "require": "./dist/common/index.cjs",
      "types": "./src/common/index.ts"
    },
    "./generated": {
      "import": "./dist/generated/index.js",
      "require": "./dist/generated/index.cjs",
      "types": "./src/generated/index.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "openapi:gen": "node scripts/generate-types.mjs"
  },
  "dependencies": {
    "@ecom/shared": "workspace:*",
    "@nestjs/swagger": "^11.0.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@ecom/config": "workspace:*",
    "openapi-typescript": "^7.13.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3"
  }
}
