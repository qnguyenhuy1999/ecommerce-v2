{
  "name": "@ecom/contracts",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": false,
  "files": [
    "src",
    "dist"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./enums": "./src/enums/index.ts",
    "./http": "./src/http/index.ts",
    "./product": "./src/product/index.ts",
    "./order": "./src/order/index.ts",
    "./auth": "./src/auth/index.ts",
    "./common": "./src/common/index.ts",
    "./generated": "./src/generated/index.ts",
    "./generated/admin": "./src/generated/admin.ts",
    "./generated/seller": "./src/generated/seller.ts",
    "./generated/storefront": "./src/generated/storefront.ts"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "openapi:gen": "node scripts/generate-types.mjs"
  },
  "dependencies": {
    "@ecom/shared": "workspace:*",
    "@nestjs/swagger": "^11.0.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@ecom/eslint-config": "workspace:*",
    "openapi-typescript": "^7.13.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3"
  }
}
