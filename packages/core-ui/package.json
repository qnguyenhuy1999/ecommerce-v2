{
  "name": "@ecom/core-ui",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./providers/ThemeProvider": {
      "types": "./dist/providers/ThemeProvider.d.ts",
      "import": "./dist/providers/ThemeProvider.mjs",
      "require": "./dist/providers/ThemeProvider.cjs"
    }
  },
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "build": "tsup",
    "build-storybook": "storybook build",
    "dev": "tsup --watch",
    "lint": "pnpm -w exec eslint src/",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@ecom/eslint-config": "workspace:*",
    "@ecom/tsconfig": "workspace:*",
    "@storybook/react-vite": "^10.3.6",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "storybook": "^10.3.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/inter": "^5.2.8",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  }
}