{
  "name": "@ecom/database",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "",
    "db:generate": "prisma generate --generator runtime_client",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "build": "prisma generate --generator runtime_client && node ./scripts/build.mjs",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3"
  },
  "devDependencies": {
    "@ecom/config": "workspace:*",
    "@nestjs/common": "^11.1.21",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.11.14",
    "dotenv": "^16.5.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.21"
  }
}
