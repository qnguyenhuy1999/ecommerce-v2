// ─── Phase 2: Platform Vouchers ────────────────────────────────

enum PlatformVoucherType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

enum PlatformVoucherStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
  DEPLETED
}

model PlatformVoucher {
  id          String                @id @default(uuid()) @db.Uuid
  code        String                @unique
  name        String
  description String?               @db.Text
  type        PlatformVoucherType
  status      PlatformVoucherStatus @default(DRAFT)

  discountValue     Decimal  @map("discount_value") @db.Decimal(12, 2)
  maxDiscountAmount Decimal? @map("max_discount_amount") @db.Decimal(12, 2)
  minOrderAmount    Decimal? @map("min_order_amount") @db.Decimal(12, 2)

  usageLimit        Int? @map("usage_limit")
  usageLimitPerUser Int? @map("usage_limit_per_user")
  usedCount         Int  @default(0) @map("used_count")

  startsAt  DateTime @map("starts_at")
  expiresAt DateTime @map("expires_at")
  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
