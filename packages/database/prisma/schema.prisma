model AutomationRule {
  id     String           @id @default(uuid()) @db.Uuid
  shopId String           @map("shop_id") @db.Uuid
  name   String
  status AutomationStatus @default(DRAFT)

  trigger    AutomationTrigger
  conditions Json?
  /// @deprecated Use AutomationRuleAction rows instead.
  /// @deprecated Column was renamed from "actions" to "actions_legacy" - run migration before deploying.
  actionsLegacy Json? @map("actions_legacy")

  priority       Int  @default(0)
  maxExecutions  Int? @map("max_executions")
  executionCount Int  @default(0) @map("execution_count")

  lastExecutedAt DateTime? @map("last_executed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  actions    AutomationRuleAction[]
  executions AutomationExecution[]

  @@index([shopId, status])
  @@index([trigger, status])
  @@map("automation_rules")
}

model AutomationRuleAction {
  id        String           @id @default(uuid()) @db.Uuid
  ruleId    String           @map("rule_id") @db.Uuid
  action    AutomationAction
  params    Json?
  sortOrder Int              @default(0) @map("sort_order")
  rule      AutomationRule   @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@map("automation_rule_actions")
}

model AutomationExecution {
  id      String  @id @default(uuid()) @db.Uuid
  ruleId  String  @map("rule_id") @db.Uuid
  success Boolean
  error   String? @db.Text

  triggerData   Json? @map("trigger_data")
  actionResults Json? @map("action_results")

  executedAt DateTime @default(now()) @map("executed_at")

  rule AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, executedAt])
  @@index([executedAt])
  @@map("automation_executions")
}

// ─── 12. Multi-region & Internationalization ──────────────────

model Region {
  id       String  @id @default(uuid()) @db.Uuid
  code     String  @unique
  name     String
  isActive Boolean @default(true) @map("is_active")

  defaultCurrencyId String? @map("default_currency_id") @db.Uuid
