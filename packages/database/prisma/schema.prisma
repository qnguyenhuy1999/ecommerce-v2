// ─── Phase 2: Product Reports ──────────────────────────────────

enum ProductReportReason {
  COUNTERFEIT
  INAPPROPRIATE
  WRONG_CATEGORY
  MISLEADING
  PROHIBITED
  IP_VIOLATION
  OTHER
