// ─── 1. Flash Sale System ─────────────────────────────────────

model FlashSaleCampaign {
  id          String          @id @default(uuid()) @db.Uuid
  name        String
  description String?         @db.Text
  status      FlashSaleStatus @default(DRAFT)

  startsAt DateTime @map("starts_at")
  endsAt   DateTime @map("ends_at")

  maxSlotsPerSeller Int     @default(5) @map("max_slots_per_seller")
  isVisible         Boolean @default(false) @map("is_visible")

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  slots FlashSaleSlot[]

  @@index([status, startsAt])
  @@index([startsAt, endsAt])
  @@map("flash_sale_campaigns")
}

model FlashSaleSlot {
  id         String              @id @default(uuid()) @db.Uuid
  campaignId String              @map("campaign_id") @db.Uuid
  shopId     String              @map("shop_id") @db.Uuid
  productId  String              @map("product_id") @db.Uuid
  variantId  String?             @map("variant_id") @db.Uuid
  status     FlashSaleSlotStatus @default(PENDING)

  originalPrice Decimal @map("original_price") @db.Decimal(12, 2)
  salePrice     Decimal @map("sale_price") @db.Decimal(12, 2)
  totalStock    Int     @map("total_stock")
  soldCount     Int     @default(0) @map("sold_count")
  purchaseLimit Int     @default(1) @map("purchase_limit")

  sortOrder Int @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  campaign FlashSaleCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, productId, variantId])
  @@index([campaignId, status])
  @@index([shopId])
  @@index([productId])
  @@map("flash_sale_slots")
}

model FlashSalePurchase {
  id       String  @id @default(uuid()) @db.Uuid
  slotId   String  @map("slot_id") @db.Uuid
  buyerId  String  @map("buyer_id") @db.Uuid
  orderId  String? @map("order_id") @db.Uuid
  quantity Int

  createdAt DateTime @default(now()) @map("created_at")

  @@index([slotId])
  @@index([buyerId, slotId])
  @@map("flash_sale_purchases")
}

// ─── 2. Ads & Sponsored Products ──────────────────────────────

model AdCampaign {
  id     String           @id @default(uuid()) @db.Uuid
  shopId String           @map("shop_id") @db.Uuid
  name   String
  type   AdType           @default(SPONSORED_PRODUCT)
  status AdCampaignStatus @default(DRAFT)

  dailyBudget Decimal  @map("daily_budget") @db.Decimal(12, 2)
  totalBudget Decimal? @map("total_budget") @db.Decimal(12, 2)
  spentAmount Decimal  @default(0) @map("spent_amount") @db.Decimal(12, 2)

  bidAmount Decimal @map("bid_amount") @db.Decimal(12, 4)

  startsAt DateTime  @map("starts_at")
  endsAt   DateTime? @map("ends_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  adGroups AdGroup[]

  @@index([shopId, status])
  @@index([status, startsAt])
  @@map("ad_campaigns")
}

model AdGroup {
  id         String @id @default(uuid()) @db.Uuid
  campaignId String @map("campaign_id") @db.Uuid
  name       String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  campaign AdCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ads      Ad[]
  keywords AdKeyword[]

  @@index([campaignId])
  @@map("ad_groups")
}

model Ad {
  id        String  @id @default(uuid()) @db.Uuid
  adGroupId String  @map("ad_group_id") @db.Uuid
  productId String  @map("product_id") @db.Uuid
  isActive  Boolean @default(true) @map("is_active")

  impressions Int     @default(0)
  clicks      Int     @default(0)
  conversions Int     @default(0)
  spent       Decimal @default(0) @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  adGroup        AdGroup        @relation(fields: [adGroupId], references: [id], onDelete: Cascade)
  impressionLogs AdImpression[]
  clickLogs      AdClick[]

  @@index([adGroupId])
  @@index([productId])
  @@map("ads")
}

model AdKeyword {
  id        String   @id @default(uuid()) @db.Uuid
  adGroupId String   @map("ad_group_id") @db.Uuid
  keyword   String
  bidAmount Decimal? @map("bid_amount") @db.Decimal(12, 4)
  isActive  Boolean  @default(true) @map("is_active")

  adGroup AdGroup @relation(fields: [adGroupId], references: [id], onDelete: Cascade)

  @@unique([adGroupId, keyword])
  @@index([keyword])
  @@map("ad_keywords")
}

model AdImpression {
  id        String  @id @default(uuid()) @db.Uuid
  adId      String  @map("ad_id") @db.Uuid
  buyerId   String? @map("buyer_id") @db.Uuid
  placement String
  cost      Decimal @default(0) @db.Decimal(12, 4)

  createdAt DateTime @default(now()) @map("created_at")

  ad Ad @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([adId, createdAt])
  @@index([createdAt])
  @@map("ad_impressions")
}

model AdClick {
  id      String  @id @default(uuid()) @db.Uuid
  adId    String  @map("ad_id") @db.Uuid
  buyerId String? @map("buyer_id") @db.Uuid
  cost    Decimal @db.Decimal(12, 4)

  createdAt DateTime @default(now()) @map("created_at")

  ad Ad @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([adId, createdAt])
  @@index([createdAt])
  @@map("ad_clicks")
}

// ─── 3. Affiliate & Creator System ───────────────────────────

model AffiliatePartner {
  id     String          @id @default(uuid()) @db.Uuid
  userId String          @unique @map("user_id") @db.Uuid
  status AffiliateStatus @default(PENDING)

  displayName String  @map("display_name")
  bio         String? @db.Text
  website     String?
  socialLinks Json?   @map("social_links")

  commissionRate Decimal @default(5) @map("commission_rate") @db.Decimal(5, 2)
  totalEarnings  Decimal @default(0) @map("total_earnings") @db.Decimal(12, 2)
  pendingBalance Decimal @default(0) @map("pending_balance") @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  links   AffiliateLink[]
  payouts CommissionPayout[]

  @@index([status])
  @@map("affiliate_partners")
}

model AffiliateLink {
  id        String  @id @default(uuid()) @db.Uuid
  partnerId String  @map("partner_id") @db.Uuid
  productId String? @map("product_id") @db.Uuid
  shopId    String? @map("shop_id") @db.Uuid
  code      String  @unique
  url       String

  clicks      Int @default(0)
  conversions Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")

  partner          AffiliatePartner      @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  trackClicks      AffiliateClick[]
  trackConversions AffiliateConversion[]

  @@index([partnerId])
  @@index([code])
  @@map("affiliate_links")
}

model AffiliateClick {
  id        String  @id @default(uuid()) @db.Uuid
  linkId    String  @map("link_id") @db.Uuid
  visitorId String? @map("visitor_id")
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent") @db.Text
  referer   String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  link AffiliateLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId, createdAt])
  @@index([createdAt])
  @@map("affiliate_clicks")
}

model AffiliateConversion {
  id      String @id @default(uuid()) @db.Uuid
  linkId  String @map("link_id") @db.Uuid
  orderId String @map("order_id") @db.Uuid
  buyerId String @map("buyer_id") @db.Uuid

  orderAmount      Decimal @map("order_amount") @db.Decimal(12, 2)
  commissionRate   Decimal @map("commission_rate") @db.Decimal(5, 2)
  commissionAmount Decimal @map("commission_amount") @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")

  link AffiliateLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
  @@index([orderId])
  @@index([createdAt])
  @@map("affiliate_conversions")
}

model CommissionPayout {
  id        String                 @id @default(uuid()) @db.Uuid
  partnerId String                 @map("partner_id") @db.Uuid
  amount    Decimal                @db.Decimal(12, 2)
  status    CommissionPayoutStatus @default(PENDING)

  paymentMethod String? @map("payment_method")
  paymentRef    String? @map("payment_ref")
  note          String? @db.Text

  processedAt DateTime? @map("processed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  partner AffiliatePartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, status])
  @@index([status])
  @@map("commission_payouts")
}

// ─── 4. Seller Subscription Plans ─────────────────────────────

model SubscriptionPlan {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique
  slug        String  @unique
  description String? @db.Text

  monthlyPrice Decimal  @map("monthly_price") @db.Decimal(12, 2)
  yearlyPrice  Decimal? @map("yearly_price") @db.Decimal(12, 2)

  productLimit Int? @map("product_limit")
  orderLimit   Int? @map("order_limit")
  storageLimit Int? @map("storage_limit")
  staffLimit   Int? @map("staff_limit")

  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  entitlements  PlanEntitlement[]
  subscriptions SellerSubscription[]

  @@map("subscription_plans")
}

model PlanEntitlement {
  id      String @id @default(uuid()) @db.Uuid
  planId  String @map("plan_id") @db.Uuid
  feature String
  value   String

  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, feature])
  @@map("plan_entitlements")
}

model SellerSubscription {
  id     String             @id @default(uuid()) @db.Uuid
  shopId String             @map("shop_id") @db.Uuid
  planId String             @map("plan_id") @db.Uuid
  status SubscriptionStatus @default(ACTIVE)

  billingCycle       String   @default("monthly") @map("billing_cycle")
  currentPeriodStart DateTime @map("current_period_start")
  currentPeriodEnd   DateTime @map("current_period_end")

  stripeSubscriptionId String? @unique @map("stripe_subscription_id")
  stripeCustomerId     String? @map("stripe_customer_id")

  cancelledAt DateTime? @map("cancelled_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  plan     SubscriptionPlan      @relation(fields: [planId], references: [id])
  invoices SubscriptionInvoice[]

  @@unique([shopId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@map("seller_subscriptions")
}

model SubscriptionInvoice {
  id             String        @id @default(uuid()) @db.Uuid
  subscriptionId String        @map("subscription_id") @db.Uuid
  amount         Decimal       @db.Decimal(12, 2)
  status         InvoiceStatus @default(DRAFT)

  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")

  stripeInvoiceId String?   @unique @map("stripe_invoice_id")
  paidAt          DateTime? @map("paid_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  subscription SellerSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([status])
  @@map("subscription_invoices")
}

// ─── 5. Livestream Commerce ───────────────────────────────────

model LivestreamSession {
  id          String           @id @default(uuid()) @db.Uuid
  shopId      String           @map("shop_id") @db.Uuid
  title       String
  description String?          @db.Text
  status      LivestreamStatus @default(SCHEDULED)

  thumbnailUrl String? @map("thumbnail_url")
  streamUrl    String? @map("stream_url")
  streamKey    String? @map("stream_key")
  replayUrl    String? @map("replay_url")

  scheduledAt DateTime  @map("scheduled_at")
  startedAt   DateTime? @map("started_at")
  endedAt     DateTime? @map("ended_at")

  viewerCount    Int @default(0) @map("viewer_count")
  peakViewers    Int @default(0) @map("peak_viewers")
  totalReactions Int @default(0) @map("total_reactions")

