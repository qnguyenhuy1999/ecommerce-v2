// ─── 1. Flash Sale System ─────────────────────────────────────

model FlashSaleCampaign {
  id          String          @id @default(uuid()) @db.Uuid
  name        String
  description String?         @db.Text
  status      FlashSaleStatus @default(DRAFT)

  startsAt DateTime @map("starts_at")
  endsAt   DateTime @map("ends_at")

  maxSlotsPerSeller Int     @default(5) @map("max_slots_per_seller")
  isVisible         Boolean @default(false) @map("is_visible")

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdByAdmin Admin?           @relation("FlashSaleCampaignCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  slots          FlashSaleSlot[]

  @@index([status, startsAt])
  @@index([startsAt, endsAt])
  @@map("flash_sale_campaigns")
}

model FlashSaleSlot {
  id         String              @id @default(uuid()) @db.Uuid
  campaignId String              @map("campaign_id") @db.Uuid
  shopId     String              @map("shop_id") @db.Uuid
  productId  String              @map("product_id") @db.Uuid
  variantId  String?             @map("variant_id") @db.Uuid
  status     FlashSaleSlotStatus @default(PENDING)

  originalPrice Decimal @map("original_price") @db.Decimal(12, 2)
  salePrice     Decimal @map("sale_price") @db.Decimal(12, 2)
  totalStock    Int     @map("total_stock")
  /// Denormalized counter. Keep in sync via application logic or a reconciliation job.
  soldCount     Int     @default(0) @map("sold_count")
  purchaseLimit Int     @default(1) @map("purchase_limit")

  sortOrder Int @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  campaign FlashSaleCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  product  Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant  ProductVariant?   @relation(fields: [variantId], references: [id], onDelete: SetNull)
  purchases FlashSalePurchase[]

  @@unique([campaignId, productId, variantId])
  @@index([campaignId, status])
  @@index([shopId])
  @@index([productId])
  @@map("flash_sale_slots")
}

model FlashSalePurchase {
  id       String  @id @default(uuid()) @db.Uuid
  slotId   String  @map("slot_id") @db.Uuid
  buyerId  String  @map("buyer_id") @db.Uuid
  orderId  String? @map("order_id") @db.Uuid
  quantity Int

  createdAt DateTime @default(now()) @map("created_at")

  slot  FlashSaleSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  buyer User          @relation(fields: [buyerId], references: [id], onDelete: Restrict)
  order Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([slotId])
  @@index([buyerId, slotId])
  @@map("flash_sale_purchases")
}

// ─── 2. Ads & Sponsored Products ──────────────────────────────

model AdCampaign {
  id     String           @id @default(uuid()) @db.Uuid
  shopId String           @map("shop_id") @db.Uuid
  name   String
  type   AdType           @default(SPONSORED_PRODUCT)
  status AdCampaignStatus @default(DRAFT)

  dailyBudget Decimal  @map("daily_budget") @db.Decimal(12, 2)
  totalBudget Decimal? @map("total_budget") @db.Decimal(12, 2)
  spentAmount Decimal  @default(0) @map("spent_amount") @db.Decimal(12, 2)

  bidAmount Decimal @map("bid_amount") @db.Decimal(12, 4)

  startsAt DateTime  @map("starts_at")
  endsAt   DateTime? @map("ends_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  adGroups AdGroup[]

  @@index([shopId])
  @@index([shopId, status])
  @@index([status, startsAt])
  @@map("ad_campaigns")
}

model AdGroup {
  id         String @id @default(uuid()) @db.Uuid
  campaignId String @map("campaign_id") @db.Uuid
  name       String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  campaign AdCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ads      Ad[]
  keywords AdKeyword[]

  @@index([campaignId])
  @@map("ad_groups")
}

model Ad {
  id        String  @id @default(uuid()) @db.Uuid
  adGroupId String  @map("ad_group_id") @db.Uuid
  productId String  @map("product_id") @db.Uuid
  isActive  Boolean @default(true) @map("is_active")

  /// Denormalized counter. Keep in sync via application logic or a reconciliation job.
  impressions Int     @default(0)
  /// Denormalized counter. Keep in sync via application logic or a reconciliation job.
  clicks      Int     @default(0)
  /// Denormalized counter. Keep in sync via application logic or a reconciliation job.
  conversions Int     @default(0)
  /// Denormalized counter. Keep in sync via application logic or a reconciliation job.
  spent       Decimal @default(0) @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  adGroup        AdGroup        @relation(fields: [adGroupId], references: [id], onDelete: Cascade)
  product        Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  impressionLogs AdImpression[]
  clickLogs      AdClick[]

  @@index([adGroupId])
  @@index([productId])
  @@map("ads")
}

model AdKeyword {
  id        String   @id @default(uuid()) @db.Uuid
  adGroupId String   @map("ad_group_id") @db.Uuid
  keyword   String
  bidAmount Decimal? @map("bid_amount") @db.Decimal(12, 4)
  isActive  Boolean  @default(true) @map("is_active")

  adGroup AdGroup @relation(fields: [adGroupId], references: [id], onDelete: Cascade)

  @@unique([adGroupId, keyword])
  @@index([keyword])
  @@map("ad_keywords")
}

model AdImpression {
  id        String  @id @default(uuid()) @db.Uuid
  adId      String  @map("ad_id") @db.Uuid
  buyerId   String? @map("buyer_id") @db.Uuid
  placement String
  cost      Decimal @default(0) @db.Decimal(12, 4)

  createdAt DateTime @default(now()) @map("created_at")

  ad    Ad    @relation(fields: [adId], references: [id], onDelete: Cascade)
  buyer User? @relation(fields: [buyerId], references: [id], onDelete: SetNull)

  @@index([adId, createdAt])
  @@index([buyerId])
  @@index([createdAt])
  @@map("ad_impressions")
}

model AdClick {
  id      String  @id @default(uuid()) @db.Uuid
  adId    String  @map("ad_id") @db.Uuid
  buyerId String? @map("buyer_id") @db.Uuid
  cost    Decimal @db.Decimal(12, 4)

  createdAt DateTime @default(now()) @map("created_at")

  ad    Ad    @relation(fields: [adId], references: [id], onDelete: Cascade)
  buyer User? @relation(fields: [buyerId], references: [id], onDelete: SetNull)

  @@index([adId, createdAt])
  @@index([buyerId])
  @@index([createdAt])
  @@map("ad_clicks")
}

// ─── 3. Affiliate & Creator System ───────────────────────────

