generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

generator runtime_client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
}

enum ShopStatus {
  PENDING
  ACTIVE
  SUSPENDED
  CLOSED
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum InventoryTransactionType {
  STOCK_IN
  STOCK_OUT
  RESERVATION
  RESERVATION_RELEASE
  ADJUSTMENT
}

enum ShipmentStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum NotificationType {
  NEW_ORDER
  ORDER_CANCELLED
  LOW_STOCK
  PRODUCT_REJECTED
  SYSTEM
}

// ─── Auth & Users ───────────────────────────────────────────────

model User {
  /// Represents all end-users: buyers, sellers, and internal staff. Admin panel users are managed separately in the Admin model.
  id            String     @id @default(uuid()) @db.Uuid
  email         String     @unique
  passwordHash  String     @map("password_hash")
  firstName     String?    @map("first_name")
  lastName      String?    @map("last_name")
  phone         String?
  emailVerified Boolean    @default(false) @map("email_verified")
  status        UserStatus @default(ACTIVE)
  /// True for internal platform users (e.g. support agents) who are not full admins but may have limited elevated access. Gate specific features in application code.
  isStaff       Boolean    @default(false) @map("is_staff")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  sessions            Session[]
  sellerProfile       SellerProfile?
  passwordResetTokens PasswordResetToken[]
  emailVerifyTokens   EmailVerifyToken[]
  conversations       Conversation[]
  chatMessages        ChatMessage[]
  flashSalePurchases  FlashSalePurchase[]
  couponUsages        CouponUsage[]
  reviews             Review[]
  returnRequests      ReturnRequest[]
  adImpressions       AdImpression[]
  adClicks            AdClick[]
  affiliateConversions AffiliateConversion[]
  loyaltyAccount      LoyaltyAccount?
  loyaltyRedemptions  LoyaltyRedemption[]
  sellers             Seller[]
  auditLogs           AuditLog[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  userAgent String?  @map("user_agent")
  ipAddress String?  @map("ip_address")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId, usedAt])
  @@map("password_reset_tokens")
}

model EmailVerifyToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId, usedAt])
  @@map("email_verify_tokens")
}

// ─── Seller & Shop ──────────────────────────────────────────────

model SellerProfile {
  /// Presence of this record is the canonical signal that a User is a seller. Always create this alongside a Shop record.
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// SellerProfile is the operational entity that owns the Shop; Seller is the admin approval/verification entity.
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop               Shop?
  adminSellerRecords Seller[]

  @@map("seller_profiles")
}

model Shop {
  id          String     @id @default(uuid()) @db.Uuid
  sellerId    String     @unique @map("seller_id") @db.Uuid
  name        String
  slug        String     @unique
  description String?    @db.Text
  logo        String?
  banner      String?
  phone       String?
  email       String?
  status      ShopStatus @default(PENDING)

  addressLine1 String? @map("address_line1")
  addressLine2 String? @map("address_line2")
  city         String?
  state        String?
  postalCode   String? @map("postal_code")
  country      String? @default("VN")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  seller                SellerProfile          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  products              Product[]
  sellerOrders          SellerOrder[]
  notifications         Notification[]
  sellerShippingMethods SellerShippingMethod[]
  coupons               Coupon[]
  warehouses            Warehouse[]
  productApprovals      ProductApproval[]
  reviewReplies         ReviewReply[]
  reviewReports         ReviewReport[]
  returnRequests        ReturnRequest[]
  sellerMetricSnapshots SellerMetricSnapshot[]
  bulkJobs              BulkJob[]
  savedFilters          SavedFilter[]
  adCampaigns           AdCampaign[]
  affiliateLinks        AffiliateLink[]
  subscription          SellerSubscription?
  livestreamSessions    LivestreamSession[]
  aiTasks               AiTask[]
  aiUsageLogs           AiUsageLog[]
  settlementItems       SettlementItem[]
  adminSellerRecord     Seller?

  @@index([sellerId])
  @@index([status])
  @@map("shops")
}

// ─── Categories ─────────────────────────────────────────────────

model Category {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  slug        String  @unique
  parentId    String? @map("parent_id") @db.Uuid
  sortOrder   Int     @default(0) @map("sort_order")
  isActive    Boolean @default(true) @map("is_active")
  description String? @db.Text
  icon        String?
  banner      String?
  metaTitle   String? @map("meta_title")
  metaDesc    String? @map("meta_desc")
  depth       Int     @default(0)
  /// path stores the materialized ancestor chain as a slash-delimited string of UUIDs for efficient subtree queries.
  path        String  @default("") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent             Category?           @relation("CategoryTree", fields: [parentId], references: [id])
  children           Category[]          @relation("CategoryTree")
  products           Product[]
  categoryAttributes CategoryAttribute[]
  couponCategories   CouponCategory[]

  @@index([parentId])
  @@index([path])
  @@map("categories")
}

// ─── Products ───────────────────────────────────────────────────

model Product {
  id          String        @id @default(uuid()) @db.Uuid
  shopId      String        @map("shop_id") @db.Uuid
  categoryId  String?       @map("category_id") @db.Uuid
  name        String
  slug        String
  description String?       @db.Text
  status      ProductStatus @default(DRAFT)

  basePrice     Decimal? @map("base_price") @db.Decimal(12, 2)
  baseSku       String?  @map("base_sku")
  /// @deprecated Only authoritative when hasVariants = false. When hasVariants = true, use ProductVariant.stock instead.
  baseStock     Int      @default(0) @map("base_stock")
  /// @deprecated Only authoritative when hasVariants = false. When hasVariants = true, use ProductVariant.stock instead.
  reservedStock Int      @default(0) @map("reserved_stock")

  hasVariants Boolean  @default(false) @map("has_variants")
  weight      Decimal? @db.Decimal(10, 3)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  shop                Shop                        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category            Category?                   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  variants            ProductVariant[]
  images              ProductImage[]
  variantOptionGroups ProductVariantOptionGroup[]
  couponProducts      CouponProduct[]
  reviews             Review[]
  conversations       Conversation[]
  productApprovals    ProductApproval[]
  flashSaleSlots      FlashSaleSlot[]
  ads                 Ad[]
  affiliateLinks      AffiliateLink[]
  livestreamProducts  LivestreamProduct[]
  aiTasks             AiTask[]
  regionalPricings    RegionalPricing[]

  @@unique([shopId, slug])
  @@index([shopId, status])
  @@index([categoryId])
  @@index([categoryId, status])
  @@index([deletedAt])
  @@map("products")
}

model ProductVariantOptionGroup {
  id        String @id @default(uuid()) @db.Uuid
  productId String @map("product_id") @db.Uuid
  name      String
  sortOrder Int    @default(0) @map("sort_order")

  product Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  options ProductVariantOption[]

  @@unique([productId, name])
  @@map("product_variant_option_groups")
}

model ProductVariantOption {
  id        String @id @default(uuid()) @db.Uuid
  groupId   String @map("group_id") @db.Uuid
  value     String
  sortOrder Int    @default(0) @map("sort_order")

  group          ProductVariantOptionGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  variantOptions ProductVariantOptionValue[]

  @@unique([groupId, value])
  @@map("product_variant_options")
}

model ProductVariant {
  id            String  @id @default(uuid()) @db.Uuid
  productId     String  @map("product_id") @db.Uuid
  sku           String?
  price         Decimal @db.Decimal(12, 2)
  stock         Int     @default(0)
  reservedStock Int     @default(0) @map("reserved_stock")
  isActive      Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product               Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  optionValues          ProductVariantOptionValue[]
  sellerOrderItems      SellerOrderItem[]
  inventoryTransactions InventoryTransaction[]
  productImages         ProductImage[]
  warehouseStocks       WarehouseStock[]
  inventoryTransferItems InventoryTransferItem[]
  flashSaleSlots        FlashSaleSlot[]
  returnItems           ReturnItem[]
  regionalPricings      RegionalPricing[]

  @@index([productId])
  @@map("product_variants")
}

model ProductVariantOptionValue {
  variantId String @map("variant_id") @db.Uuid
  optionId  String @map("option_id") @db.Uuid

  variant ProductVariant       @relation(fields: [variantId], references: [id], onDelete: Cascade)
  option  ProductVariantOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([variantId, optionId])
  @@map("product_variant_option_values")
}

model ProductImage {
  id        String  @id @default(uuid()) @db.Uuid
  productId String  @map("product_id") @db.Uuid
  variantId String? @map("variant_id") @db.Uuid
  url       String
  alt       String?
  sortOrder Int     @default(0) @map("sort_order")
  isCover   Boolean @default(false) @map("is_cover")

  createdAt DateTime @default(now()) @map("created_at")

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([variantId])
  @@map("product_images")
}

// ─── Orders ─────────────────────────────────────────────────────

model Order {
  id          String      @id @default(uuid()) @db.Uuid
  buyerId     String      @map("buyer_id") @db.Uuid
  totalAmount Decimal     @map("total_amount") @db.Decimal(12, 2)
  /// Independently managed aggregate order status. It is not currently derived automatically from child SellerOrder records.
  status      OrderStatus @default(PENDING)

  shippingName    String? @map("shipping_name")
  shippingPhone   String? @map("shipping_phone")
  shippingAddress String? @map("shipping_address") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sellerOrders        SellerOrder[]
  reviews             Review[]
  couponUsages        CouponUsage[]
  flashSalePurchases  FlashSalePurchase[]

  @@index([buyerId])
  @@index([status])
  @@map("orders")
}

model SellerOrder {
  id       String      @id @default(uuid()) @db.Uuid
  orderId  String      @map("order_id") @db.Uuid
  shopId   String      @map("shop_id") @db.Uuid
  subtotal Decimal     @db.Decimal(12, 2)
  /// Seller-fulfillment status managed per shop order. Parent Order.status remains independently managed.
  status   OrderStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order     Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shop      Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  items     SellerOrderItem[]
  shipments Shipment[]
  auditLogs OrderAuditLog[]
  returnRequests ReturnRequest[]
  settlementItems SettlementItem[]

  @@index([shopId, status])
  @@index([orderId])
  @@map("seller_orders")
}

model SellerOrderItem {
  id            String  @id @default(uuid()) @db.Uuid
  sellerOrderId String  @map("seller_order_id") @db.Uuid
  variantId     String  @map("variant_id") @db.Uuid
  productName   String  @map("product_name")
  variantLabel  String? @map("variant_label")
  quantity      Int
  unitPrice     Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice    Decimal @map("total_price") @db.Decimal(12, 2)

  sellerOrder SellerOrder    @relation(fields: [sellerOrderId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  returnItems ReturnItem[]

  @@index([sellerOrderId])
  @@index([variantId])
  @@map("seller_order_items")
}

model OrderAuditLog {
  id            String  @id @default(uuid()) @db.Uuid
  sellerOrderId String  @map("seller_order_id") @db.Uuid
  fromStatus    String  @map("from_status")
  toStatus      String  @map("to_status")
  note          String? @db.Text
  performedBy   String? @map("performed_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  sellerOrder      SellerOrder @relation(fields: [sellerOrderId], references: [id], onDelete: Cascade)
  performedByAdmin Admin?      @relation("OrderAuditLogPerformedBy", fields: [performedBy], references: [id], onDelete: SetNull)

  @@index([sellerOrderId])
  @@map("order_audit_logs")
}

// ─── Inventory ──────────────────────────────────────────────────

model InventoryTransaction {
  id        String                   @id @default(uuid()) @db.Uuid
  variantId String                   @map("variant_id") @db.Uuid
  type      InventoryTransactionType
  quantity  Int
  reference String?
  note      String?                  @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([createdAt])
  @@map("inventory_transactions")
}

// ─── Shipping ───────────────────────────────────────────────────

model ShippingProvider {
  id       String  @id @default(uuid()) @db.Uuid
  name     String  @unique
  code     String  @unique
  isActive Boolean @default(true) @map("is_active")
  logoUrl  String? @map("logo_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sellerShippingMethods SellerShippingMethod[]
  shipments             Shipment[]

  @@map("shipping_providers")
}

model SellerShippingMethod {
  id         String  @id @default(uuid()) @db.Uuid
  shopId     String  @map("shop_id") @db.Uuid
  providerId String  @map("provider_id") @db.Uuid
  isEnabled  Boolean @default(true) @map("is_enabled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shop     Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  provider ShippingProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([shopId, providerId])
  @@map("seller_shipping_methods")
}

model Shipment {
  id             String         @id @default(uuid()) @db.Uuid
  sellerOrderId  String         @map("seller_order_id") @db.Uuid
  providerId     String         @map("provider_id") @db.Uuid
  trackingNumber String?        @map("tracking_number")
  status         ShipmentStatus @default(PENDING)
  isPrimary      Boolean        @default(true) @map("is_primary")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sellerOrder SellerOrder      @relation(fields: [sellerOrderId], references: [id], onDelete: Cascade)
  provider    ShippingProvider @relation(fields: [providerId], references: [id], onDelete: Restrict)

  @@index([sellerOrderId])
  @@index([trackingNumber])
  @@map("shipments")
}

// ─── Notifications ──────────────────────────────────────────────

model Notification {
  id       String           @id @default(uuid()) @db.Uuid
  shopId   String           @map("shop_id") @db.Uuid
  type     NotificationType
  title    String
  message  String           @db.Text
  isRead   Boolean          @default(false) @map("is_read")
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ─── Audit ──────────────────────────────────────────────────────

/// General-purpose audit log for application-level events. Use OrderAuditLog for order status changes and AdminAuditLog for admin actions.
model AuditLog {
  id        String  @id @default(uuid()) @db.Uuid
  userId    String? @map("user_id") @db.Uuid
  action    String
  entity    String
  entityId  String? @map("entity_id") @db.Uuid
  oldData   Json?   @map("old_data")
  newData   Json?   @map("new_data")
  ipAddress String? @map("ip_address")

  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Phase 2 Enums ─────────────────────────────────────────────

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum CouponScope {
  ALL_PRODUCTS
  SPECIFIC_PRODUCTS
  SPECIFIC_CATEGORIES
}

enum CouponStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
  DEPLETED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
}

enum ReturnStatus {
  REQUESTED
  REVIEWING
  APPROVED
  REJECTED
  RETURN_SHIPPING
  RECEIVED
  REFUNDED
  CLOSED
}

enum ReturnReason {
  DEFECTIVE
  WRONG_ITEM
  NOT_AS_DESCRIBED
  CHANGED_MIND
  DAMAGED_IN_SHIPPING
  OTHER
}

enum RefundMethod {
  ORIGINAL_PAYMENT
  STORE_CREDIT
  BANK_TRANSFER
}

enum ApprovalStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

enum BulkJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  PARTIALLY_COMPLETED
}

enum BulkJobType {
  PRODUCT_IMPORT
  PRODUCT_EXPORT
  INVENTORY_UPDATE
  PRICE_UPDATE
}

enum ChatMessageType {
  TEXT
  IMAGE
  PRODUCT
  SYSTEM
}

enum InventoryTransferStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum UserEventType {
  VIEW
  CLICK
  ADD_TO_CART
  PURCHASE
  SEARCH
  WISHLIST
  SHARE
  REVIEW
}

enum UserEventEntityType {
  PRODUCT
  SHOP
  CATEGORY
  SEARCH_RESULT
  AD
}

enum ProductScoreType {
  POPULARITY
  RELEVANCE
  QUALITY
  TRENDING
  CONVERSION_RATE
}

enum ProductRelationType {
  FREQUENTLY_BOUGHT_TOGETHER
  SIMILAR
  UPSELL
  CROSS_SELL
  ACCESSORY
}

enum LoyaltyRewardType {
  COUPON
  POINTS_MULTIPLIER
  FREE_SHIPPING
  CASHBACK
  PHYSICAL_GIFT
}

// ─── Coupons & Promotions ──────────────────────────────────────

model Coupon {
  id          String       @id @default(uuid()) @db.Uuid
  shopId      String       @map("shop_id") @db.Uuid
  code        String
  name        String
  description String?      @db.Text
  type        CouponType
  scope       CouponScope  @default(ALL_PRODUCTS)
  status      CouponStatus @default(DRAFT)

  discountValue     Decimal  @map("discount_value") @db.Decimal(12, 2)
  maxDiscountAmount Decimal? @map("max_discount_amount") @db.Decimal(12, 2)
  minOrderAmount    Decimal? @map("min_order_amount") @db.Decimal(12, 2)

  usageLimit        Int? @map("usage_limit")
  usageLimitPerUser Int? @map("usage_limit_per_user")
  /// Denormalized counter. Keep in sync via application logic or a reconciliation job.
  usedCount         Int  @default(0) @map("used_count")

  autoApply Boolean @default(false) @map("auto_apply")

  startsAt  DateTime @map("starts_at")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shop             Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  couponProducts   CouponProduct[]
  couponCategories CouponCategory[]
  couponUsages     CouponUsage[]

  @@unique([shopId, code])
  @@index([shopId, status])
  @@index([status, expiresAt])
  @@index([startsAt, expiresAt])
  @@map("coupons")
}

model CouponProduct {
  couponId  String @map("coupon_id") @db.Uuid
  productId String @map("product_id") @db.Uuid

  coupon  Coupon  @relation(fields: [couponId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([couponId, productId])
  @@map("coupon_products")
}

model CouponCategory {
  couponId   String @map("coupon_id") @db.Uuid
  categoryId String @map("category_id") @db.Uuid

  coupon   Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([couponId, categoryId])
  @@map("coupon_categories")
}

model CouponUsage {
  id        String   @id @default(uuid()) @db.Uuid
  couponId  String   @map("coupon_id") @db.Uuid
  buyerId   String   @map("buyer_id") @db.Uuid
  orderId   String?  @map("order_id") @db.Uuid
  discount  Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  buyer  User   @relation(fields: [buyerId], references: [id], onDelete: Restrict)
  order  Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([couponId])
  @@index([buyerId])
  @@map("coupon_usages")
}

// ─── Product Reviews ───────────────────────────────────────────

model Review {
  id        String       @id @default(uuid()) @db.Uuid
  productId String       @map("product_id") @db.Uuid
  buyerId   String       @map("buyer_id") @db.Uuid
  orderId   String?      @map("order_id") @db.Uuid
  rating    Int
  title     String?
  comment   String?      @db.Text
  status    ReviewStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer   User    @relation(fields: [buyerId], references: [id], onDelete: Restrict)
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  images  ReviewImage[]
  replies ReviewReply[]
  reports ReviewReport[]

  @@index([productId, status])
  @@index([orderId])
  @@index([buyerId])
  @@index([rating])
  @@index([createdAt])
  @@map("reviews")
}

model ReviewImage {
  id        String @id @default(uuid()) @db.Uuid
  reviewId  String @map("review_id") @db.Uuid
  url       String
  sortOrder Int    @default(0) @map("sort_order")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_images")
}

model ReviewReply {
  id       String @id @default(uuid()) @db.Uuid
  reviewId String @map("review_id") @db.Uuid
  shopId   String @map("shop_id") @db.Uuid
  message  String @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_replies")
}

model ReviewReport {
  id       String  @id @default(uuid()) @db.Uuid
  reviewId String  @map("review_id") @db.Uuid
  shopId   String  @map("shop_id") @db.Uuid
  reason   String
  details  String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Restrict)

  @@index([reviewId])
  @@map("review_reports")
}

// ─── Seller Chat ───────────────────────────────────────────────

model Conversation {
  /// A conversation is scoped to a shop-buyer-product triple. productId may be null for general shop inquiries.
  id        String  @id @default(uuid()) @db.Uuid
  shopId    String  @map("shop_id") @db.Uuid
  buyerId   String  @map("buyer_id") @db.Uuid
  productId String? @map("product_id") @db.Uuid

  lastMessageAt   DateTime? @map("last_message_at")
  lastMessageText String?   @map("last_message_text") @db.Text

  sellerUnread Int @default(0) @map("seller_unread")
  buyerUnread  Int @default(0) @map("buyer_unread")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  buyer    User           @relation(fields: [buyerId], references: [id], onDelete: Restrict)
  product  Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  messages ChatMessage[]

  @@unique([shopId, buyerId, productId])
  @@index([shopId, lastMessageAt])
  @@index([buyerId])
  @@map("conversations")
}

model ChatMessage {
  id             String          @id @default(uuid()) @db.Uuid
  conversationId String          @map("conversation_id") @db.Uuid
  senderId       String          @map("sender_id") @db.Uuid
  type           ChatMessageType @default(TEXT)
  content        String          @db.Text
  metadata       Json?

  isReadBySeller Boolean @default(false) @map("is_read_by_seller")
  isReadByBuyer  Boolean @default(false) @map("is_read_by_buyer")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("chat_messages")
}

// ─── Returns & Refunds ─────────────────────────────────────────

model ReturnRequest {
  id            String       @id @default(uuid()) @db.Uuid
  sellerOrderId String       @map("seller_order_id") @db.Uuid
  buyerId       String       @map("buyer_id") @db.Uuid
  /// Denormalized from SellerOrder.shopId for query performance. Must be kept in sync with the parent SellerOrder.
  shopId        String       @map("shop_id") @db.Uuid
  status        ReturnStatus @default(REQUESTED)
  reason        ReturnReason
  description   String?      @db.Text

  refundAmount Decimal       @map("refund_amount") @db.Decimal(12, 2)
  refundMethod RefundMethod? @map("refund_method")

  trackingNumber String?   @map("tracking_number")
  resolvedAt     DateTime? @map("resolved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sellerOrder SellerOrder      @relation(fields: [sellerOrderId], references: [id], onDelete: Restrict)
  buyer      User             @relation(fields: [buyerId], references: [id], onDelete: Restrict)
  shop       Shop             @relation(fields: [shopId], references: [id], onDelete: Restrict)
  items      ReturnItem[]
  evidence   ReturnEvidence[]
  timeline   ReturnTimeline[]

  @@index([shopId, status])
  @@index([sellerOrderId])
  @@index([buyerId])
  @@index([createdAt])
  @@map("return_requests")
}

model ReturnItem {
  id                String @id @default(uuid()) @db.Uuid
  returnRequestId   String @map("return_request_id") @db.Uuid
  sellerOrderItemId String @map("seller_order_item_id") @db.Uuid
  variantId         String? @map("variant_id") @db.Uuid
  quantity          Int

  returnRequest    ReturnRequest    @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  sellerOrderItem  SellerOrderItem  @relation(fields: [sellerOrderItemId], references: [id], onDelete: Cascade)
  variant          ProductVariant?  @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([returnRequestId])
  @@map("return_items")
}

model ReturnEvidence {
  id              String  @id @default(uuid()) @db.Uuid
  returnRequestId String  @map("return_request_id") @db.Uuid
  uploadedBy      String  @map("uploaded_by") @db.Uuid
  url             String
  description     String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  returnRequest    ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  uploadedByAdmin Admin         @relation("ReturnEvidenceUploadedBy", fields: [uploadedBy], references: [id], onDelete: Restrict)

  @@index([returnRequestId])
  @@map("return_evidence")
}

model ReturnTimeline {
  id              String  @id @default(uuid()) @db.Uuid
  returnRequestId String  @map("return_request_id") @db.Uuid
  fromStatus      String  @map("from_status")
  toStatus        String  @map("to_status")
  note            String? @db.Text
  performedBy     String? @map("performed_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  returnRequest    ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  performedByAdmin Admin?        @relation("ReturnTimelinePerformedBy", fields: [performedBy], references: [id], onDelete: SetNull)

  @@index([returnRequestId])
  @@map("return_timeline")
}

// ─── Product Approval Workflow ─────────────────────────────────

model ProductApproval {
  id        String         @id @default(uuid()) @db.Uuid
  productId String         @map("product_id") @db.Uuid
  shopId    String         @map("shop_id") @db.Uuid
  status    ApprovalStatus @default(PENDING_REVIEW)

  submittedAt DateTime  @default(now()) @map("submitted_at")
  reviewedAt  DateTime? @map("reviewed_at")
  reviewedBy  String?   @map("reviewed_by") @db.Uuid

  rejectionReason String? @map("rejection_reason") @db.Text
  revisionNote    String? @map("revision_note") @db.Text
  version         Int     @default(1)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product         Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)
  shop            Shop                     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  reviewedByAdmin Admin?                   @relation("ProductApprovalReviewedBy", fields: [reviewedBy], references: [id], onDelete: SetNull)
  history         ProductApprovalHistory[]

  @@index([productId])
  @@index([shopId, status])
  @@index([status])
  @@map("product_approvals")
}

model ProductApprovalHistory {
  id          String  @id @default(uuid()) @db.Uuid
  approvalId  String  @map("approval_id") @db.Uuid
  fromStatus  String  @map("from_status")
  toStatus    String  @map("to_status")
  note        String? @db.Text
  performedBy String? @map("performed_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  approval         ProductApproval @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  performedByAdmin Admin?          @relation("ProductApprovalHistoryPerformedBy", fields: [performedBy], references: [id], onDelete: SetNull)

  @@index([approvalId])
  @@map("product_approval_history")
}

// ─── Advanced Inventory / Warehouses ───────────────────────────

model Warehouse {
  id        String  @id @default(uuid()) @db.Uuid
  shopId    String  @map("shop_id") @db.Uuid
  name      String
  code      String
  address   String? @db.Text
  isActive  Boolean @default(true) @map("is_active")
  isDefault Boolean @default(false) @map("is_default")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shop          Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  stocks        WarehouseStock[]
  transfersFrom InventoryTransfer[] @relation("TransferFrom")
  transfersTo   InventoryTransfer[] @relation("TransferTo")

  @@unique([shopId, code])
  @@index([shopId])
  @@map("warehouses")
}

model WarehouseStock {
  id          String @id @default(uuid()) @db.Uuid
  warehouseId String @map("warehouse_id") @db.Uuid
  variantId   String @map("variant_id") @db.Uuid
  stock       Int    @default(0)
  reserved    Int    @default(0)
  safetyStock Int    @default(0) @map("safety_stock")

  updatedAt DateTime @updatedAt @map("updated_at")

  warehouse Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, variantId])
  @@index([variantId])
  @@map("warehouse_stocks")
}

model InventoryTransfer {
  id              String                  @id @default(uuid()) @db.Uuid
  shopId          String                  @map("shop_id") @db.Uuid
  fromWarehouseId String                  @map("from_warehouse_id") @db.Uuid
  toWarehouseId   String                  @map("to_warehouse_id") @db.Uuid
  status          InventoryTransferStatus @default(PENDING)
  note            String?                 @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  fromWarehouse Warehouse               @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse               @relation("TransferTo", fields: [toWarehouseId], references: [id])
  items         InventoryTransferItem[]

  @@index([shopId])
  @@index([status])
  @@map("inventory_transfers")
}

model InventoryTransferItem {
  id         String @id @default(uuid()) @db.Uuid
  transferId String @map("transfer_id") @db.Uuid
  variantId  String @map("variant_id") @db.Uuid
  quantity   Int

  transfer InventoryTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  variant  ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([transferId])
  @@map("inventory_transfer_items")
}

// ─── Seller Performance Metrics ────────────────────────────────

model SellerMetricSnapshot {
  id     String   @id @default(uuid()) @db.Uuid
  shopId String   @map("shop_id") @db.Uuid
  date   DateTime @db.Date

  totalOrders        Int    @default(0) @map("total_orders")
  cancelledOrders    Int    @default(0) @map("cancelled_orders")
  lateShipments      Int    @default(0) @map("late_shipments")
  totalRefunds       Int    @default(0) @map("total_refunds")
  messagesReceived   Int    @default(0) @map("messages_received")
  messagesResponded  Int    @default(0) @map("messages_responded")
  avgResponseMinutes Float? @map("avg_response_minutes")

  cancellationRate Float @default(0) @map("cancellation_rate")
  lateShipmentRate Float @default(0) @map("late_shipment_rate")
  responseRate     Float @default(0) @map("response_rate")
  refundRate       Float @default(0) @map("refund_rate")
  sellerScore      Float @default(100) @map("seller_score")

  createdAt DateTime @default(now()) @map("created_at")

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, date])
  @@index([shopId])
  @@index([shopId, date])
  @@map("seller_metric_snapshots")
}

// ─── Bulk Import/Export ────────────────────────────────────────

model BulkJob {
  id     String        @id @default(uuid()) @db.Uuid
  shopId String        @map("shop_id") @db.Uuid
  type   BulkJobType
  status BulkJobStatus @default(QUEUED)

  fileName  String  @map("file_name")
  fileUrl   String? @map("file_url")
  resultUrl String? @map("result_url")

  totalRows     Int @default(0) @map("total_rows")
  processedRows Int @default(0) @map("processed_rows")
  successRows   Int @default(0) @map("success_rows")
  errorRows     Int @default(0) @map("error_rows")

  errors      Json?
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([shopId, type])
  @@index([status])
  @@index([createdAt])
  @@map("bulk_jobs")
}

// ─── Saved Filters / Views ─────────────────────────────────────

model SavedFilter {
  id        String  @id @default(uuid()) @db.Uuid
  shopId    String  @map("shop_id") @db.Uuid
  name      String
  entity    String
  filters   Json
  isDefault Boolean @default(false) @map("is_default")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([shopId, entity])
  @@map("saved_filters")
}

