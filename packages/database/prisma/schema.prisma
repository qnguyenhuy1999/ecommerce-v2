  @@index([linkId])
  @@index([orderId])
  @@index([createdAt])
  @@map("affiliate_conversions")
}

model CommissionPayout {
  id        String                 @id @default(uuid()) @db.Uuid
  partnerId String                 @map("partner_id") @db.Uuid
  amount    Decimal                @db.Decimal(12, 2)
