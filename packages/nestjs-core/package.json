{
  "name": "@ecom/nestjs-core",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./src/index.ts"
    },
    "./openapi": {
      "import": "./dist/openapi.js",
      "require": "./dist/openapi.cjs",
      "types": "./src/openapi/index.ts"
    }
  },
  "scripts": {
    "dev": "",
    "build": "tsup",
    "lint": "pnpm exec eslint --no-error-on-unmatched-pattern src/",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ecom/contracts": "workspace:*",
    "@nestjs/common": "^11.1.21",
    "@nestjs/swagger": "^11.4.3",
    "nestjs-pino": "^4.2.0",
    "pino-http": "^11.0.0",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@ecom/config": "workspace:*",
    "@nestjs/common": "^11.1.21",
    "@nestjs/swagger": "^11.4.3",
    "@types/express": "^5.0.6",
    "express": "^5.2.1",
    "pino-pretty": "^13.0.0",
    "rxjs": "^7.8.2",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.21",
    "@nestjs/swagger": "^11.4.3",
    "express": "^5.2.1",
    "rxjs": "^7.8.2"
  },
  "peerDependenciesMeta": {
    "@nestjs/swagger": {
      "optional": true
    }
  }
}
