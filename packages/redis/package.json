{
  "name": "@ecom/redis",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "pnpm exec eslint --no-error-on-unmatched-pattern src/",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.21",
    "ioredis": "^5.6.0"
  },
  "devDependencies": {
    "@ecom/config": "workspace:*",
    "@types/node": "^25.9.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3"
  }
}
