{
  "name": "@ecom/shared",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "import": "./dist/constants/index.js",
      "require": "./dist/constants/index.cjs"
    },
    "./pagination/core": {
      "types": "./dist/pagination/core/index.d.ts",
      "import": "./dist/pagination/core/index.js",
      "require": "./dist/pagination/core/index.cjs"
    },
    "./pagination/nestjs": {
      "types": "./dist/pagination/nestjs/index.d.ts",
      "import": "./dist/pagination/nestjs/index.js",
      "require": "./dist/pagination/nestjs/index.cjs"
    },
    "./pagination/prisma": {
      "types": "./dist/pagination/prisma/index.d.ts",
      "import": "./dist/pagination/prisma/index.js",
      "require": "./dist/pagination/prisma/index.cjs"
    },
    "./pagination/react": {
      "types": "./dist/pagination/react/index.d.ts",
      "import": "./dist/pagination/react/index.js",
      "require": "./dist/pagination/react/index.cjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.cjs"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js",
      "require": "./dist/errors/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "peerDependenciesMeta": {
    "@nestjs/swagger": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "peerDependencies": {
    "@nestjs/swagger": ">=7.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@ecom/config": "workspace:*",
    "@nestjs/swagger": "^11.0.6",
    "@tanstack/react-query": "^5.100.10",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "client-only": "^0.0.1",
    "react": "^19.2.6",
    "server-only": "^0.0.1",
    "vitest": "^4.1.6"
  }
}
