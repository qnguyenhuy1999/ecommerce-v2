{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "commonjs",
    "declaration": false,
    "declarationMap": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "paths": {
      "@/*": ["src/*"],
      "@ecom/constants": ["../constants/src"],
      "@ecom/api-types": ["../api-types/src"],
      "@ecom/database": ["../database/src"],
      "@ecom/email": ["../email/src"],
      "@ecom/redis": ["../redis/src"],
      "@ecom/shared": ["../shared/src"],
      "@ecom/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test"]
}
