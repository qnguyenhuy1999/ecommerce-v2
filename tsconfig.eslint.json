{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./packages/config/src/tooling/tsconfig/eslint.json",
  "include": [
    "apps/*/src/**/*.ts",
    "apps/*/src/**/*.tsx",
    "apps/*/next-env.d.ts",
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.turbo/**",
    "**/.next/**",
    "**/storybook-static/**",
    "**/*.stories.tsx"
  ]
}
