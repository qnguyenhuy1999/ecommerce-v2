{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "tsconfig.json",
        "package.json",
        "tsup.config.ts",
        "tailwind.config.*",
        "next.config.*",
        "postcss.config.*",
        "$NODE_ENV"
      ],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "swagger:gen": {
      "cache": false,
      "dependsOn": ["^build"],
      "outputs": ["openapi/**"]
    },
    "openapi:gen": {
      "cache": false,
      "dependsOn": ["swagger:gen"]
    }
  }
}
